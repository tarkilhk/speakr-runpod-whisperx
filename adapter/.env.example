RUNPOD_API_KEY=your-runpod-api-key
# Optional override for local mocks. Default: https://api.runpod.io/graphql
# RUNPOD_GRAPHQL_URL=http://127.0.0.1:19001/graphql

# Preferred: deploy a fresh Pod on demand from a RunPod template.
RUNPOD_TEMPLATE_ID=your-runpod-template-id
RUNPOD_GPU_TYPE_IDS=NVIDIA GeForce RTX 4090,NVIDIA GeForce RTX 3090,NVIDIA RTX A5000
RUNPOD_CLOUD_TYPE=SECURE
RUNPOD_GPU_COUNT=1
RUNPOD_CONTAINER_DISK_GB=template-container-disk-gb  # must match the template's containerDiskInGb; not inherited automatically
RUNPOD_POD_NAME=speakr-whisperx
RUNPOD_IDLE_ACTION=terminate

ADAPTER_WHISPERX_TOKEN=replace-with-shared-secret
RUNPOD_WRAPPER_PORT=9000
# Path where the adapter stores the active pod ID (template mode).
# Change to a shared volume path when running the drain as a separate container so both services
# can access the same file.  Default: /tmp/speakr-runpod-active-pod-id (ephemeral, not shared).
# RUNPOD_ACTIVE_POD_ID_PATH=/data/speakr-runpod-active-pod-id
RUNPOD_READINESS_TIMEOUT_SECONDS=600
RUNPOD_STUCK_INIT_TIMEOUT_SECONDS=300
RUNPOD_REQUEST_TIMEOUT_SECONDS=1800
RUNPOD_IDLE_STOP_SECONDS=30
RUNPOD_RETRY_AFTER_SECONDS=300
MAX_FILE_SIZE_MB=0
LOG_LEVEL=INFO

# Before idle terminate: HTTPS pull from the RunPod wrapper, then emit each line on logger
# whisperx-adapter.runpod_pod_capture (point Grafana Alloy or your log driver at adapter stdout).
# Fixed-pod idle stop skips automatic drain to avoid replaying persistent pod logs.
ADAPTER_DRAIN_POD_LOGS_ON_IDLE=true
ADAPTER_POD_LOG_FETCH_TIMEOUT_SECONDS=120
